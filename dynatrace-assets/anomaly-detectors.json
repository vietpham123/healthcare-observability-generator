        "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
        "input": [
          {
            "key": "query",
            "value": "fetch logs | filter healthcare.pipeline == \"healthcare-network\" AND network.event.type == \"INTERFACE\" AND loglevel == \"ERROR\" | makeTimeseries count=count(), interval:1m"
