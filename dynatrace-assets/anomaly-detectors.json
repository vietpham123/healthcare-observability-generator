    "value": {
      "enabled": true,
      "title": "Healthcare - Mirth Queue Backup",
      "description": "Detects Mirth integration engine queue depth exceeding safe threshold.",
      "source": "healthcare-obs-gen",
      "executionSettings": {
        "actor": "078dfce6-0342-4cf4-9fae-87da8cf31659"
      },
      "analyzer": {
        "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
        "input": [
          {
            "key": "query",
            "value": "timeseries avg(healthcare.mirth.channel.queue.depth), interval:1m"
          },
          {
            "key": "threshold",
            "value": "50"
          },
          {
            "key": "alertCondition",
            "value": "ABOVE"
          },
          {
            "key": "alertOnMissingData",
            "value": "false"
          },
          {
            "key": "violatingSamples",
            "value": "3"
          },
          {
            "key": "slidingWindow",
            "value": "5"
          },
          {
            "key": "dealertingSamples",
            "value": "5"
          }
        ]
      },
      "eventTemplate": {
        "properties": [
          {
            "key": "event.name",
            "value": "Healthcare - Mirth Connect Queue Backup"
          },
          {
            "key": "event.description",
            "value": "Mirth queue depth exceeded 50 messages. Baseline ~2-5. HL7 interface delivery failure - lab results and orders backing up."
          },
          {
            "key": "event.type",
            "value": "CUSTOM_ALERT"
          },
          {
            "key": "healthcare.alert.category",
            "value": "integration"
          },
          {
            "key": "healthcare.scenario",
            "value": "hl7-interface-failure"
          }
        ]
      }
    }
  },
