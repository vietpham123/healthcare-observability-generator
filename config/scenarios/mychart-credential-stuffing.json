{
  "name": "MyChart Credential Stuffing Attack",
  "description": "Automated credential stuffing against MyChart patient portal from external IPs. Correlates WAF/firewall threat logs with Epic MyChart authentication failures. Some credentials succeed, leading to PHI access.",
  "volume_multiplier": 1.0,
  "mychart_multiplier": 5.0,
  "max_sessions": 20,
  "epic_events": {
    "phases": [
      {
        "name": "Credential Stuffing Wave 1 (T+0)",
        "offset_minutes": 0,
        "events": [
          {"event_type": "WPSEC_LOGIN_FAIL", "count": 500, "source": "MyChart", "description": "Mass MyChart login failures from credential stuffing"},
          {"event_type": "FAILEDLOGIN", "count": 300, "source": "MyChart"}
        ]
      },
      {
        "name": "Some Credentials Succeed (T+5min)",
        "offset_minutes": 5,
        "events": [
          {"event_type": "HKU_LOGIN", "count": 8, "source": "MyChart", "description": "Handful of stolen credentials work"},
          {"event_type": "PATIENT_ACCESS_LOG", "count": 8, "description": "MyChart sessions view patient records"},
          {"event_type": "WPSEC_EXPORT", "count": 3, "description": "Attacker downloads medical records through MyChart"}
        ]
      },
      {
        "name": "Rate Limiting Kicks In (T+8min)",
        "offset_minutes": 8,
        "events": [
          {"event_type": "LOGIN_BLOCKED", "count": 200, "source": "MyChart", "description": "Epic rate limiter triggers"},
          {"event_type": "FAILEDLOGIN", "count": 50, "source": "MyChart", "description": "Reduced rate — attacker throttled"}
        ]
      }
    ]
  },
  "network_correlation": {
    "enabled": true,
    "description": "External IPs hitting MyChart through Palo Alto DMZ, Citrix ADC rate-limiting visible, F5 WAF blocking malicious patterns",
    "events": [
      {
        "offset_seconds": 0,
        "device": "kcrmc-fw-pa-01",
        "event_type": "traffic_allow",
        "params": {"src_zone": "untrust", "dst_zone": "dmz", "dst_ip": "203.0.113.10", "dst_port": 443, "app": "ssl", "sessions_per_second": 500},
        "description": "Massive connection rate to MyChart VIP from distributed IPs"
      },
      {
        "offset_seconds": 5,
        "device": "kcrmc-citrix-01",
        "event_type": "lb_vserver_connections_high",
        "params": {"vserver": "vs_mychart_443", "connections": 2500, "threshold": 500},
        "description": "Citrix ADC MyChart VServer overwhelmed with connections"
      },
      {
        "offset_seconds": 10,
        "device": "kcrmc-f5-01",
        "event_type": "asm_violation",
        "params": {"violation_type": "Brute Force Attack", "uri": "/mychart/Authentication/Login", "request_count": 500, "source_ips": "multiple"},
        "description": "F5 ASM detects brute force pattern"
      },
      {
        "offset_seconds": 30,
        "device": "kcrmc-f5-01",
        "event_type": "asm_block",
        "params": {"uri": "/mychart/Authentication/Login", "blocked_ips": 45, "reason": "Rate exceeded threshold"},
        "description": "F5 ASM begins blocking source IPs"
      },
      {
        "offset_seconds": 60,
        "device": "kcrmc-fw-pa-01",
        "event_type": "threat_detect",
        "params": {"threat_type": "vulnerability", "threat_name": "HTTP Credential Stuffing Attempt", "severity": "high", "src_zone": "untrust"},
        "description": "Palo Alto threat signature matches credential stuffing pattern"
      },
      {
        "offset_seconds": 480,
        "device": "kcrmc-fw-pa-01",
        "event_type": "traffic_deny",
        "params": {"src_zone": "untrust", "dst_ip": "203.0.113.10", "action": "deny", "rule": "emergency-mychart-block"},
        "description": "Security team applies emergency block rule on MyChart ingress"
      }
    ],
    "flow_anomalies": [
      {"src_subnet": "external", "dst_ip": "203.0.113.10", "dst_port": 443, "increase_factor": 50.0, "description": "External → MyChart VIP 50x normal rate"},
      {"src_subnet": "external", "dst_ip": "203.0.113.10", "dst_port": 443, "unique_src_ips": 2000, "description": "2000+ unique source IPs — distributed attack"}
    ]
  },
  "indicators": [
    "MyChart login failure rate 500x normal is the first indicator",
    "Success rate ~1.5% typical for credential stuffing with leaked databases",
    "Citrix ADC connection count mirrors Epic authentication failure rate",
    "F5 ASM brute force detection provides automated mitigation",
    "Small number of successful logins result in PHI export — data breach",
    "Distributed source IPs visible in NetFlow indicate botnet involvement"
  ]
}
