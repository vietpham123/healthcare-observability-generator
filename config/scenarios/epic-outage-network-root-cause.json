{
  "name": "Epic Hyperspace Outage — Citrix/Network Root Cause",
  "description": "Core switch interface flap causes Citrix ADC to lose backend health checks. F5 marks Interconnect pool members down. Epic users experience Hyperspace disconnects and FHIR API 503s. Root cause is network, not Epic.",
  "volume_multiplier": 0.3,
  "mychart_multiplier": 0.5,
  "max_sessions": 5,
  "curve_overrides": {
    "8": 0.2, "9": 0.1, "10": 0.3, "11": 0.6
  },
  "epic_events": {
    "phases": [
      {
        "name": "Pre-outage normal (T-5min)",
        "offset_minutes": -5,
        "events": [
          {"event_type": "HKU_LOGIN", "count": 10, "description": "Normal login activity"},
          {"event_type": "chart_review", "count": 15}
        ]
      },
      {
        "name": "Outage begins (T+0)",
        "offset_minutes": 0,
        "events": [
          {"event_type": "WPSEC_LOGIN_FAIL", "count": 30, "description": "Mass login failures — Citrix sessions dropping"},
          {"event_type": "FAILEDLOGIN", "count": 20}
        ]
      },
      {
        "name": "Users retry (T+2min)",
        "offset_minutes": 2,
        "events": [
          {"event_type": "WPSEC_LOGIN_FAIL", "count": 50, "description": "Users hammering login — increasing failure rate"},
          {"event_type": "FAILEDLOGIN", "count": 35},
          {"event_type": "IC_SERVICE_AUDIT", "count": 5, "description": "FHIR API calls returning 503"}
        ]
      },
      {
        "name": "Recovery (T+10min)",
        "offset_minutes": 10,
        "events": [
          {"event_type": "HKU_LOGIN", "count": 40, "description": "Mass re-login after network recovery"},
          {"event_type": "CTO_LOGIN", "count": 35},
          {"event_type": "CONTEXTCHANGE", "count": 30}
        ]
      }
    ]
  },
  "network_correlation": {
    "enabled": true,
    "description": "Interface flap on core-01 → Citrix ADC health check failure → F5 pool member down → mass session drops",
    "events": [
      {
        "offset_seconds": 0,
        "device": "lrmc-core-01",
        "event_type": "interface_down",
        "params": {"interface": "TenGigabitEthernet1/0/2", "reason": "link-flap"},
        "description": "Core switch uplink to Epic distribution flaps"
      },
      {
        "offset_seconds": 2,
        "device": "lrmc-core-01",
        "event_type": "interface_up",
        "params": {"interface": "TenGigabitEthernet1/0/2"},
        "description": "Link recovers briefly"
      },
      {
        "offset_seconds": 5,
        "device": "lrmc-core-01",
        "event_type": "interface_down",
        "params": {"interface": "TenGigabitEthernet1/0/2", "reason": "link-flap"},
        "description": "Link flaps again — STP reconverging"
      },
      {
        "offset_seconds": 10,
        "device": "lrmc-citrix-01",
        "event_type": "lb_vserver_down",
        "params": {"vserver": "vs_epic_hyperspace_443", "vip": "10.10.10.100", "reason": "Backend health check failed"},
        "description": "Citrix ADC marks Epic Hyperspace VServer DOWN"
      },
      {
        "offset_seconds": 12,
        "device": "lrmc-citrix-01",
        "event_type": "service_down",
        "params": {"service": "svc_epic_ctx_01", "ip": "10.10.10.50", "reason": "Health check timed out"},
        "description": "Individual Citrix backend service marked down"
      },
      {
        "offset_seconds": 15,
        "device": "lrmc-f5-01",
        "event_type": "ltm_pool_member_down",
        "params": {"pool": "/Common/epic_interconnect_pool", "member": "10.10.10.30:443", "reason": "Monitor check failed"},
        "description": "F5 marks Interconnect pool member DOWN"
      },
      {
        "offset_seconds": 20,
        "device": "lrmc-fw-pa-01",
        "event_type": "traffic_deny",
        "params": {"src_ip": "10.10.20.0/24", "dst_ip": "10.10.10.100", "action": "deny", "reason": "destination unreachable"},
        "description": "Firewall starts denying traffic to Epic VIP — host unreachable"
      },
      {
        "offset_seconds": 600,
        "device": "lrmc-core-01",
        "event_type": "interface_up",
        "params": {"interface": "TenGigabitEthernet1/0/2"},
        "description": "Link stabilizes after 10 minutes"
      },
      {
        "offset_seconds": 620,
        "device": "lrmc-citrix-01",
        "event_type": "lb_vserver_up",
        "params": {"vserver": "vs_epic_hyperspace_443", "vip": "10.10.10.100"},
        "description": "Citrix ADC VServer recovers"
      },
      {
        "offset_seconds": 625,
        "device": "lrmc-f5-01",
        "event_type": "ltm_pool_member_up",
        "params": {"pool": "/Common/epic_interconnect_pool", "member": "10.10.10.30:443"},
        "description": "F5 Interconnect pool member recovers"
      }
    ]
  },
  "indicators": [
    "Core switch interface flap (UPDOWN) is the FIRST event in the chain",
    "Citrix VServer down occurs 10 seconds after interface flap — proves network causation",
    "Epic login failures begin AFTER Citrix down — not before",
    "F5 pool member down confirms Interconnect also impacted",
    "Recovery order: network up → Citrix up → F5 up → Epic logins resume",
    "Temporal correlation proves root cause is network, not Epic application"
  ]
}
